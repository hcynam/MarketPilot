# Select one server-side provider. Never prefix secrets with VITE_.
AI_PROVIDER=groq
AI_PROVIDER_TIMEOUT_MS=25000

# Groq (used when AI_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b

# Gemini alternative (used when AI_PROVIDER=gemini)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Public browser configuration. Put either the current Supabase publishable key
# or the legacy anon key in VITE_SUPABASE_ANON_KEY. It is public by design;
# authorization is enforced by Supabase Row Level Security.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
# Server-only Netlify Function configuration. Never prefix the service role key with VITE_.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase Send SMS HTTP Hook -> Kavenegar VerifyLookup (server-only).
KAVENEGAR_API_KEY=
KAVENEGAR_VERIFY_TEMPLATE=
SUPABASE_SMS_HOOK_SECRET=

# Hosted Supabase phone Auth also requires Phone provider setup in the Supabase dashboard
# (Twilio, MessageBird, Vonage or another supported provider), CAPTCHA, OTP expiry,
# resend interval and Auth rate limits. Provider credentials stay in Supabase, not this app.
